javascript:(function(){var c=document.createElement('div');var themeColor='#8E44AD';c.style="position:fixed;top:50px;left:10px;z-index:10000;background:#222;color:#fff;padding:12px;border-radius:10px;font-family:sans-serif;width:220px;box-shadow:0 10px 20px rgba(0,0,0,0.5);border-top:4px solid "+themeColor+";touch-action:none;user-select:none";var ox=0,oy=0;c.ontouchstart=function(e){ox=e.touches[0].clientX-c.offsetLeft;oy=e.touches[0].clientY-c.offsetTop;};c.ontouchmove=function(e){c.style.left=(e.touches[0].clientX-ox)+'px';c.style.top=(e.touches[0].clientY-oy)+'px';e.preventDefault();};function addBtn(txt,fn,mt=5){var b=document.createElement('button');b.className='menu-btn';b.innerText=txt;b.style="width:100%;margin-top:"+mt+"px;background:"+themeColor+";color:white;border:none;padding:8px;border-radius:4px;font-weight:bold;cursor:pointer";b.onclick=fn;c.appendChild(b);return b;}var t=document.createElement('div');t.id='menu-title';t.innerText='☰ Drag Me';t.style="font-weight:bold;margin-bottom:10px;text-align:center;cursor:move;color:"+themeColor;c.appendChild(t);var cp=document.createElement('input');cp.type='color';cp.value=themeColor;cp.style="width:100%;height:25px;border:none;background:none;cursor:pointer;margin-bottom:5px";cp.oninput=function(){var nc=cp.value;c.style.borderTopColor=nc;t.style.color=nc;document.querySelectorAll('.menu-btn').forEach(b=>{if(!b.dataset.custom)b.style.background=nc;});themeColor=nc;};c.appendChild(cp);var v=null;addBtn('Stay Awake',async function(){try{if(!v){v=await navigator.wakeLock.request('screen');this.style.background='#27ae60';this.dataset.custom='true';}else{v.release();v=null;this.style.background=themeColor;delete this.dataset.custom;}}catch(e){alert('Not supported')}},0);addBtn('Edit Text',function(){var d=document.designMode==='on';document.designMode=d?'off':'on';this.style.background=d?themeColor:'#f39c12';if(!d)this.dataset.custom='true';else delete this.dataset.custom;});var ai=document.createElement('input');ai.type='number';ai.value='1000';ai.style="width:92%;margin-top:10px;background:#333;color:#fff;border:1px solid #555;padding:5px";c.appendChild(ai);addBtn('Start Clicker',function(){if(window.acInt){clearInterval(window.acInt);window.acInt=null;this.innerText='Start Clicker';}else{window.acInt=setInterval(()=>{let e=document.elementFromPoint(window.innerWidth/2,window.innerHeight/2);if(e)e.click()},parseInt(ai.value));this.innerText='Stop Clicker';}});var ei=document.createElement('textarea');ei.placeholder='JS Code...';ei.style="width:92%;margin-top:10px;height:40px;background:#333;color:#fff;border:1px solid #555;padding:5px";c.appendChild(ei);addBtn('Execute',function(){try{eval(ei.value)}catch(e){alert(e)}});var closeBtn=addBtn('Close',function(){if(window.acInt)clearInterval(window.acInt);if(v)v.release();document.body.removeChild(c)},15);closeBtn.style.background='#c0392b';closeBtn.dataset.custom='true';document.body.appendChild(c);})();
